{
  "name": "com.samsung.smart",
  "version": "1.0.0",
  "description": "Samsung SmartTV",
  "main": "app.ts",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "npm run test:typecheck",
    "test": "env TS_NODE_PROJECT=tsconfig.eslint.json TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"verbatimModuleSyntax\":false}' mocha -r ts-node/register 'test/**/*.ts'",
    "posttest": "homey app validate && prettier --write app.json",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "test:typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "lint": "npm run format:check && eslint app.ts drivers lib test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/balmli/com.samsung.smart.git"
  },
  "author": "Bjørnar Almli",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/balmli/com.samsung.smart/issues"
  },
  "homepage": "https://github.com/balmli/com.samsung.smart#readme",
  "dependencies": {
    "@balmli/homey-samsung-encryption": "^1.0.0",
    "homey-log": "2.1.0",
    "http.min": "2.1.0",
    "is-port-reachable": "3.0.0",
    "macaddress": "0.5.1",
    "node-ssdp-lite": "0.2.0",
    "p-queue": "6.6.2",
    "wake_on_lan": "1.0.0",
    "ws": "8.12.0",
    "xml2json-light": "1.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/chai": "^4.3.20",
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0.3.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.12.0",
    "chai": "^4.5.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "mocha": "^11.7.6",
    "prettier": "^3.9.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
